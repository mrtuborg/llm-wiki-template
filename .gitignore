# Generated pipeline artifacts (per-run outputs)
wiki/updates/
wiki/compiled/
wiki/graph/
wiki/synthesis/
wiki/decisions/
pipeline/reconstructed/

# Per-instance config (set when instantiating from template)
pipeline/config.md

# Obsidian workspace state
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Third-party plugins (not tracked — installed by user)
# Use wildcard so we can negate our own plugin below
.obsidian/plugins/*/
# Track our plugin (negate works when parent is not itself ignored)
!.obsidian/plugins/llm-wiki-semantic-graph/

# OS
.DS_Store
Thumbs.db

